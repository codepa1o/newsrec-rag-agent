APP_ENV=dev
DATA_DIR=data
DATABASE_PATH=data/newsrec.db
MIND_NEWS_PATH=data/mind/MINDsmall_train/news.tsv
MIND_BEHAVIORS_PATH=data/mind/MINDsmall_train/behaviors.tsv
CHROMA_PERSIST_DIR=data/chroma

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
RERANK_MODEL=qwen3-rerank

RECOMMEND_TOP_K=10
RETRIEVAL_TOP_K=40
USE_CHROMA=false
USE_DASHSCOPE=false
