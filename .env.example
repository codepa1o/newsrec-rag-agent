APP_ENV=dev
DATA_DIR=data
DATABASE_PATH=data/newsrec.db
UPLOAD_DIR=data/uploads
MODEL_DIR=data/models
LTR_MODEL_PATH=data/models/ltr_model.json
MIND_NEWS_PATH=data/sample/news.tsv
MIND_BEHAVIORS_PATH=data/sample/behaviors.tsv
CHROMA_PERSIST_DIR=data/chroma

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
RERANK_MODEL=qwen3-rerank
AI_CACHE_ENABLED=true
AI_TIMEOUT_SECONDS=30
MAX_UPLOAD_MB=20
MAX_EVAL_USERS=80

RECOMMEND_TOP_K=20
RETRIEVAL_TOP_K=80
USE_CHROMA=false
USE_DASHSCOPE=false
